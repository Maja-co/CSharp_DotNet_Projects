<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MinForsteMauiApp.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Spacing="25"
            Padding="30,0"
            VerticalOptions="Center">

            <Button x:Name="MinKnap" 
                    Text="Jeg er en stor knap" 
                    TextColor="White" 
                    FontSize="12" />
            
            <HorizontalStackLayout Spacing="10">
                <CheckBox x:Name="VisKnapCheck" />
                <Label Text="Vis knap" VerticalOptions="Center" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
